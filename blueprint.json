{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "login": true,
    "steps": [
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "kate & tom/'s demo"
			}
		},
        {
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github.com/eirichmond/katomswold/blob/main/katomswold.zip"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/eirichmond/kate-toms-core",
					"ref": "HEAD"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/eirichmond/kateandtomsblueprint/refs/heads/main/content.xml"
			}
		},
		{
			"step": "runPHPWithOptions",
			"options": {
				"code": "<?php require_once '/wordpress/wp-load.php'; update_option('show_on_front', 'page');?>",
				"body": "Static page set with runPHPWithOptions"
			}
		},
		{
			"step": "runPHPWithOptions",
			"options": {
				"code": "<?php require_once '/wordpress/wp-load.php'; update_option('page_on_front', '4');?>",
				"body": "Home page set with runPHPWithOptions"
			}
		},
		{
			"step": "runPHPWithOptions",
			"options": {
				"code": "<?php require_once '/wordpress/wp-load.php'; update_option('page_for_posts', '12');?>",
				"body": "Blog set with runPHPWithOptions"
			}
		},
		{
			"step": "writeFile",
			"path": "/wordpress/wp-content/mu-plugins/rewrite.php",
			"data": "<?php /* Use pretty permalinks */ add_action( 'after_setup_theme', function() { global $wp_rewrite; $wp_rewrite->set_permalink_structure('/%postname%/'); $wp_rewrite->flush_rules(); } );"
		}
    ]
}